# Application
APP_NAME=ReTrace
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./retrace.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/retrace

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
HOST=0.0.0.0
PORT=8000
WEBSOCKET_PORT=8001

# LLM Providers
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Reasoning Model
REASONING_MODEL=gpt-4o
VISION_MODEL=gpt-4-vision-preview

# Supabase (community cloud auth) — JWKS only; asymmetric JWT signing required in Supabase.
SUPABASE_URL=https://ndpkjdwupcvtglrqjfwr.supabase.co

# Gateway (vendor-agnostic LLM proxy — "direct" = no gateway)
GATEWAY_PROVIDER=direct
GATEWAY_BASE_URL=https://llm.lumenatech.ai
GATEWAY_ADMIN_KEY=

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json
